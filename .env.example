# ============================================================
# .env.example — תבנית למשתני סביבה של הפרויקט
# ============================================================
# העתק את הקובץ הזה ל-.env ומלא את הערכים האמיתיים.
# הקובץ .env נמצא ב-.gitignore ולא יידחף ל-GitHub.
# ============================================================

# --- מפתחות API למודלים ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- GitHub ---
# Personal Access Token עם הרשאת repo
GITHUB_TOKEN=your-github-token-here

# --- הגדרות כלליות ---
# סביבת ריצה: development | production
NODE_ENV=development
